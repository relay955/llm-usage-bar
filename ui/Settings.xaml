<Window x:Class="LLMUsageBar.ui.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:LLMUsageBar.ui"
        mc:Ignorable="d"
        Title="설정"
        Height="220"
        Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="설정"
                   Foreground="#FFFFFFFF"
                   FontSize="18"
                   FontWeight="SemiBold" />

        <Grid Grid.Row="1"
              Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="96" />
                <ColumnDefinition Width="36" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="자동갱신 주기"
                       Foreground="#FFE8E8E8"
                       FontSize="13"
                       VerticalAlignment="Center" />

            <TextBox x:Name="RefreshIntervalMinutesTextBox"
                     Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     HorizontalContentAlignment="Right"
                     Padding="8,0"
                     PreviewTextInput="RefreshIntervalMinutesTextBox_PreviewTextInput" />

            <TextBlock Grid.Column="2"
                       Text="분"
                       Margin="8,0,0,0"
                       Foreground="#FFE8E8E8"
                       FontSize="13"
                       VerticalAlignment="Center" />
        </Grid>

        <TextBlock x:Name="ValidationMessageTextBlock"
                   Grid.Row="2"
                   Margin="0,12,0,0"
                   Foreground="#FFFF453A"
                   FontSize="12"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="취소"
                    Width="72"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click" />
            <Button Content="저장"
                    Width="72"
                    Height="30"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
