<Window x:Class="LLMUsageBar.ui.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:LLMUsageBar.ui"
        mc:Ignorable="d"
        Title="설정"
        Height="420"
        Width="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E">
    <Window.Resources>
        <local:SettingsVm x:Key="Vm" />
    </Window.Resources>
    <Window.DataContext>
        <Binding Source="{StaticResource Vm}" />
    </Window.DataContext>

    <DockPanel Margin="18">
        <Border DockPanel.Dock="Left"
                Width="132"
                Margin="0,0,18,0"
                BorderBrush="#FF333333"
                BorderThickness="0,0,1,0">
            <ListBox SelectedIndex="0"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#FFE8E8E8">
                <ListBoxItem Content="General" Padding="10,8" />
                <ListBoxItem Content="Openrouter" Padding="10,8" />
            </ListBox>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="설정" Foreground="#FFFFFFFF" FontSize="18" FontWeight="SemiBold" />

            <Grid Grid.Row="1"
                  Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="36" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="자동갱신 주기"
                           Foreground="#FFE8E8E8"
                           FontSize="13"
                           VerticalAlignment="Center" />

                <TextBox Grid.Column="1"
                         Height="30"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Right"
                         Padding="8,0"
                         Text="{Binding AppSettings.RefreshIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="2"
                           Text="분"
                           Margin="8,0,0,0"
                           Foreground="#FFE8E8E8"
                           FontSize="13"
                           VerticalAlignment="Center" />
            </Grid>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <TextBlock
                    Margin="0,12,0,0" Foreground="#FFFF453A" FontSize="12"
                    Text="{Binding ValidationMessage}"
                    TextWrapping="Wrap" />
                <Button Content="취소"
                        Width="72" Height="30" Margin="0,0,8,0"
                        Command="{Binding CancelCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
                <Button Content="저장"
                        Width="72" Height="30" Command="{Binding SaveCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
