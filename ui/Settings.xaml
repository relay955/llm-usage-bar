<Window x:Class="LLMUsageBar.ui.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:LLMUsageBar.ui"
        mc:Ignorable="d"
        Title="설정"
        Height="520"
        Width="720"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E">
    <Window.Resources>
        <local:SettingsVm x:Key="Vm" />
        <Style x:Key="SettingsNavListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FFE8E8E8" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        </Style>
        <Style x:Key="SettingsNavListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="#FFBDBDBD" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemBackground"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="SelectionBar"
                                        Width="3"
                                        Height="18"
                                        Margin="6,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="#FF4CC2FF"
                                        CornerRadius="2"
                                        Opacity="0" />
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="#FF2A2A2A" />
                                <Setter Property="Foreground" Value="#FFF2F2F2" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBackground" Property="Background" Value="#FF26333A" />
                                <Setter TargetName="SelectionBar" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF777777" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsContentControlStyle" TargetType="{x:Type ContentControl}">
            <Setter Property="Margin" Value="0,20,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                    <Setter Property="Content">
                        <Setter.Value>
                            <local:GeneralSettingsControl />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                    <Setter Property="Content">
                        <Setter.Value>
                            <local:OpenRouterSettingsControl />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Window.DataContext>
        <Binding Source="{StaticResource Vm}" />
    </Window.DataContext>

    <DockPanel>
        <Border DockPanel.Dock="Left"
                Width="146"
                Margin="0,0,18,0"
                Padding="8"
                Background="#FF242424"
                BorderBrush="#FF3A3A3A"
                BorderThickness="1">
            <ListBox SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                     Style="{StaticResource SettingsNavListBoxStyle}"
                     ItemContainerStyle="{StaticResource SettingsNavListBoxItemStyle}">
                <ListBoxItem Content="General" />
                <ListBoxItem Content="Openrouter" />
            </ListBox>
        </Border>


        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="12">
            <TextBlock
                Margin="0,12,0,0" Foreground="#FFFF453A" FontSize="12"
                Text="{Binding ValidationMessage}"
                TextWrapping="Wrap" />
            <Button Content="취소"
                    Width="72" Height="30" Margin="0,0,8,0"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
            <Button Content="저장"
                    Width="72" Height="30" Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
        </StackPanel>

        <StackPanel>
            <ContentControl Style="{StaticResource SettingsContentControlStyle}" />
        </StackPanel>
    </DockPanel>
</Window>
