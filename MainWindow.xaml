<Window x:Class="LLMUsageBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LLMUsageBar"
        mc:Ignorable="d"
        Title="LLMUsageBar"
        Width="230"
        Height="48"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <local:MainWindowVm x:Key="Vm" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Window.DataContext>
        <Binding Source="{StaticResource Vm}" />
    </Window.DataContext>
    
    <Border BorderThickness="1"
            Background="#01FFFFFF">
        <Border.Resources>
            <Style x:Key="HoverSettingsButtonStyle"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource IconButton}">
                <Setter Property="Visibility" Value="Hidden" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}"
                                 Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="HoverProviderButtonStyle"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource IconButton}">
                <Setter Property="Visibility" Value="Hidden" />
                <Setter Property="Foreground" Value="#FF353535" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}"
                                       Value="True" />
                            <Condition Binding="{Binding HasMultipleProviders}"
                                       Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Visibility" Value="Visible" />
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="ProviderNameButtonStyle"
                   TargetType="{x:Type Button}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Border.Resources>
        <DockPanel>
            <StackPanel Margin="5,0,5,0" DockPanel.Dock="Left" VerticalAlignment="Center">
                <Button Width="15"
                        Height="15"
                        Margin="0,0,0,1"
                        Padding="0"
                        MinWidth="0"
                        Style="{StaticResource HoverProviderButtonStyle}"
                        Command="{Binding PreviousProviderCommand}"
                        ToolTip="이전 프로바이더">
                    <Image Source="Assets/arrow-up.png" Width="10" Height="10" Stretch="Uniform" />
                </Button>
                <Button Width="15"
                        Height="15"
                        Margin="0,1,0,0"
                        Padding="0"
                        MinWidth="0"
                        Style="{StaticResource HoverProviderButtonStyle}"
                        Command="{Binding NextProviderCommand}"
                        ToolTip="다음 프로바이더">
                    <Image Source="Assets/arrow-down.png" Width="10" Height="10" Stretch="Uniform" />
                </Button>
            </StackPanel>
            <Button Width="28"
                    Height="28"
                    Margin="0,0,5,0"
                    Style="{StaticResource HoverSettingsButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Command="{Binding OpenSettingsCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    DockPanel.Dock="Right"
                    ToolTip="설정"
                    Foreground="#FFFFFFFF"
                    FontSize="15">
                <Image Source="Assets/settings.png" Width="18" Height="18" Stretch="Uniform" />
            </Button>
            <Button Width="28"
                    Height="28"
                    Margin="0,0,2,0"
                    Style="{StaticResource HoverSettingsButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Command="{Binding ManualRefreshCommand}"
                    DockPanel.Dock="Right"
                    ToolTip="수동갱신"
                    Foreground="#FFFFFFFF">
                <Image Source="Assets/refresh.png" Width="18" Height="18" Stretch="Uniform" />
            </Button>
            <StackPanel HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,1">
                    <Button Style="{StaticResource ProviderNameButtonStyle}"
                            Command="{Binding OpenProviderQuotaCommand}"
                            ToolTip="{Binding ProviderQuotaUrl}">
                        <TextBlock Text="{Binding ProviderName}"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="#777777" />
                    </Button>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Margin="6,0,0,0"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="#C0392B" />
                </StackPanel>
                
                <!-- balance provider - no max balance (single text) -->
                <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="#353535"
                           Visibility="{Binding ShowCreditText, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Run Text="{Binding CreditText}" />
                </TextBlock>
                
                <!-- balance provider - using max balance (progress bar)  -->
                <Grid VerticalAlignment="Center"
                      Visibility="{Binding HasBalanceDisplay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        BorderThickness="2"
                        BorderBrush="#CDCDCD" >
                    <ProgressBar Height="14"
                                 Width="100"
                                 Value="{Binding BalanceRatio, Converter={StaticResource RatioToPercentConverter}}"
                                 Foreground="#FFFFFF"
                                 Background="#CDCDCD"/>
                    </Border>
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="#353535"
                               Margin="0,0,0,1">
                        <Run>
                            <Run.Text>
                                <MultiBinding Converter="{StaticResource BalanceTextConverter}">
                                    <Binding Path="MaxBalance" />
                                    <Binding Path="BalanceRatio" />
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>
                </Grid>
                
                <!-- dual quota provider -->
                <StackPanel VerticalAlignment="Center"
                            Visibility="{Binding HasDualQuota, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ShortQuotaLabel}"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="#555555"
                                   VerticalAlignment="Center" />
                        <Grid Grid.Column="1">
                            <Border
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                BorderThickness="1"
                                BorderBrush="#CDCDCD" >
                                <ProgressBar Height="9"
                                             Width="100"
                                             Value="{Binding HourlyQuotaRatio, Converter={StaticResource RatioToPercentConverter}}"
                                             Foreground="#FFFFFF"
                                             Background="#CDCDCD"/>
                            </Border>
                            <TextBlock Text="{Binding HourlyQuotaText}"
                                       FontSize="8"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="#353535" />
                        </Grid>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding LongQuotaLabel}"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="#555555"
                                   VerticalAlignment="Center" />
                        <Grid Grid.Column="1">
                            <Border
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                BorderThickness="1"
                                BorderBrush="#CDCDCD" >
                                <ProgressBar Height="9"
                                             Width="100"
                                             Value="{Binding WeeklyQuotaRatio, Converter={StaticResource RatioToPercentConverter}}"
                                             Foreground="#FFFFFF"
                                             Background="#CDCDCD"/>
                            </Border>
                            <TextBlock Text="{Binding WeeklyQuotaText}"
                                       FontSize="8"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="#353535" />
                        </Grid>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
