<Window x:Class="LLMUsageBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LLMUsageBar"
        mc:Ignorable="d"
        Title="LLMUsageBar"
        Width="230"
        Height="40"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <local:MainWindowVm x:Key="Vm" />
    </Window.Resources>
    <Window.DataContext>
        <Binding Source="{StaticResource Vm}" />
    </Window.DataContext>
    
    <Border BorderThickness="1"
            Background="#01FFFFFF">
        <Border.Resources>
            <Style x:Key="HoverSettingsButtonStyle"
                   TargetType="{x:Type Button}"
                   BasedOn="{StaticResource IconButton}">
                <Setter Property="Visibility" Value="Hidden" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}"
                                 Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Resources>
        <Grid>
            <TextBlock Text="{Binding CreditText}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#353535"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            <Button Width="28"
                    Height="28"
                    Margin="0,0,5,0"
                    Style="{StaticResource HoverSettingsButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Command="{Binding OpenSettingsCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    ToolTip="설정"
                    Foreground="#FFFFFFFF"
                    FontSize="15">
                <Image Source="Assets/settings.png" Width="18" Height="18" Stretch="Uniform" />
            </Button>
        </Grid>
    </Border>
</Window>
